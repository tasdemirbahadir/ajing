# Required: private or public YouTube Music/YouTube playlist URL
PLAYLIST_URL=https://music.youtube.com/playlist?list=YOUR_PLAYLIST_ID

# Playlist fetch mode:
# - auto: uses youtube-api if GOOGLE_* OAuth vars are set, otherwise yt-dlp
# - yt-dlp: fetch playlist using yt-dlp metadata endpoint
# - youtube-api: fetch playlist using Google OAuth refresh token
PLAYLIST_FETCH_MODE=auto

# Optional cookie source for yt-dlp playlist fetch and/or cookie-based track downloads
YTDLP_COOKIES_FROM_BROWSER=
# YTDLP_COOKIES_FILE=C:/path/to/cookies.txt

# If true, track downloads use cookies from above config
YTDLP_USE_COOKIES_FOR_DOWNLOAD=false

# OAuth settings for private playlist fetch without browser cookies
# Client type mode for oauth helper: auto | desktop | web
GOOGLE_OAUTH_CLIENT_TYPE=desktop
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# Used by oauth helper in web mode; desktop mode uses dynamic 127.0.0.1 loopback URI
GOOGLE_REDIRECT_URI=http://localhost:53682

# Optional if PLAYLIST_URL is not set
# GOOGLE_PLAYLIST_ID=PLxxxxxxxxxxxxxxxx

# Binaries (change only if not in PATH)
YTDLP_BIN=yt-dlp
FFMPEG_BIN=ffmpeg
FFPROBE_BIN=ffprobe
FFPLAY_BIN=ffplay

# Caching and output
CACHE_DIR=.cache
STATE_FILE=.cache/dj-state.json
OUTPUT_FILE=.cache/output/ai-dj-mix.wav
# Session metadata file for desktop UI controls (track timeline, IDs, durations)
DJ_SESSION_FILE=.cache/output/ai-dj-session.json

# Behavior
BPM_SAMPLE_SECONDS=300
TEMPO_MATCH_POOL_SIZE=1
MAX_TEMPO_SHIFT_PERCENT=12
MIN_TRANSITION_SECONDS=40
MAX_TRANSITION_SECONDS=88
PLAY_AUDIO=true
# If PLAY_AUDIO=false, mark all planned tracks as played when render completes
MARK_PLAYED_WHEN_NOT_PLAYING=true
CLEAN_TEMP_AFTER_RUN=false
# Disable animated spinners (useful for desktop embedded console / redirected logs)
DISABLE_SPINNERS=false

# Optional: reset all songs to unplayed on every start
AUTO_RESET_ON_START=false
